# ─────────────────────────────────────────────────────────────
# DAMA KITCHEN — environment configuration
# Copy to .env.local and fill in real values. None are required for the
# WhatsApp routing path; placeholders keep the site functional in dev.
# ─────────────────────────────────────────────────────────────

# Production site URL (used for canonical, OG, sitemap).
NEXT_PUBLIC_SITE_URL=https://damakitchen.id

# WhatsApp business number in E.164 WITHOUT the leading "+" (wa.me format).
NEXT_PUBLIC_WHATSAPP_NUMBER=6281181207201

# Live commerce channels. TODO: real store URLs.
NEXT_PUBLIC_SHOPEE_URL=https://shopee.co.id/
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/
NEXT_PUBLIC_GOFOOD_URL=https://gofood.co.id/
NEXT_PUBLIC_GRAB_URL=https://food.grab.com/id/id/

# Contact. TODO: real address.
NEXT_PUBLIC_CONTACT_EMAIL=halo@damakitchen.id

# Optional inquiry email adapter (lib/email.ts). Leave blank to skip email;
# WhatsApp remains the primary channel. TODO: wire a provider (e.g. Resend).
INQUIRY_EMAIL_API_KEY=
INQUIRY_EMAIL_TO=
